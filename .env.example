# ── Авторизация в веб-панели ───────────────────────────────
# Логин и пароль для входа в интерфейс.
# Обязательно смените значения перед запуском в проде.
AUTH_LOGIN=admin
AUTH_PASSWORD=admin

# ── Подпись JWT-токенов ────────────────────────────────────
# Секрет, которым подписываются токены сессии.
# Сгенерируйте случайную строку, например:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-random-secret-key-in-production
